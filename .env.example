# --- Connection ---------------------------------------------------------
# Full URL of the EWS endpoint. Required unless EWS_AUTODISCOVER=true.
EWS_ENDPOINT=https://mail.example.com/EWS/Exchange.asmx

# Set to true to locate the endpoint via Exchange Autodiscover instead of
# EWS_ENDPOINT. Leave false when you know the endpoint URL (recommended).
EWS_AUTODISCOVER=false

# --- Credentials --------------------------------------------------------
# Primary SMTP address of the mailbox.
EWS_EMAIL=user@example.com

# Login for authentication. Defaults to EWS_EMAIL when empty.
# For NTLM use the DOMAIN\username form.
EWS_USERNAME=

# Password. Never commit the real .env file.
EWS_PASSWORD=

# --- Authentication -----------------------------------------------------
# One of: basic | ntlm | digest | gssapi | sspi.
# Leave empty to let exchangelib autodetect the auth type.
EWS_AUTH_TYPE=

# Mailbox access type: delegate | impersonation. Default: delegate.
EWS_ACCESS_TYPE=delegate

# --- TLS ----------------------------------------------------------------
# If the server uses a certificate from an internal CA, do NOT disable
# verification - point requests to your CA bundle instead (see README):
# REQUESTS_CA_BUNDLE=C:\path\to\internal-ca.pem

# DANGER: disables TLS certificate verification entirely. Makes the
# connection vulnerable to man-in-the-middle attacks. Last resort only.
EWS_INSECURE_TLS=false

# --- Tuning -------------------------------------------------------------
# HTTP timeout for EWS requests, seconds. Default: 30.
EWS_TIMEOUT=30

# Hard upper bound for the list_messages "limit" argument. Default: 100.
EWS_MAX_LIST_LIMIT=100
